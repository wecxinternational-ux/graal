# Turso (libSQL) — получить на https://turso.tech
# Локальная разработка без этих переменных использует файл server/graal.db
TURSO_DATABASE_URL=libsql://your-db-name.turso.io
TURSO_AUTH_TOKEN=your-auth-token-here

# Секрет для JWT (можно оставить по умолчанию для разработки)
JWT_SECRET=graal_secret_key_2024
